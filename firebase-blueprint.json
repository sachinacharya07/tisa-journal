{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "streak": { "type": "integer" },
        "lastJournaled": { "type": "string", "format": "date-time" },
        "sharedJournalIds": { "type": "array", "items": { "type": "string" } },
        "settings": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number" },
            "theme": { "type": "string" },
            "writingFont": { "type": "string" },
            "silentMode": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Entry": {
      "title": "Journal Entry",
      "description": "A single journal entry, which can be personal or shared.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "journalId": { "type": "string" },
        "type": { "type": "string", "enum": ["journal", "lyrics", "page"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isFavorite": { "type": "boolean" },
        "isPinned": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "reactions": { "type": "object" },
        "comments": { "type": "array" }
      },
      "required": ["userId", "journalId", "type", "createdAt"]
    },
    "SharedJournal": {
      "title": "Shared Journal",
      "description": "A collaborative space for multiple users.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "creatorId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "memberNames": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["inviteCode", "creatorId", "memberIds"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Journal entries across all sections."
    },
    "/sharedJournals/{journalId}": {
      "schema": "SharedJournal",
      "description": "Shared journal spaces."
    }
  }
}
